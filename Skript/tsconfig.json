{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false
  },
  // Die TUI wird aktuell nicht weiterentwickelt und ist nach der per-Fach-
  // Stunden-Umstellung nicht mehr typkompatibel. Sie bleibt im Repo als
  // Feature-Option, wird aber erst beim Revive wieder in den TS-Check
  // aufgenommen. Siehe plan.md → Abschnitt "TUI".
  "exclude": ["tui", "node_modules"]
}
